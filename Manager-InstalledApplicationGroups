# 2. Define your Automation Account details
$ResourceGroupName     = "feipcu1-eutworkstations-rg-001"
$AutomationAccountName = "feipcu1-intune"
$WorkerRunbookName     = "InstalledApplicationGroups" 
$HybridWorkerGroupName = "IntuneWorkerGroup"

# 3. Authenticate to Azure via Managed Identity
try {
    Write-Output "Connecting to Azure via Managed Identity..."
    Connect-AzAccount -Identity | Out-Null
} catch {
    Write-Error "Failed to connect to Azure. Ensure the Automation Account has a Managed Identity configured. Error: $_"
    exit
}

$TotalApps = $MasterAppList.Count
Write-Output "Starting worker jobs for $TotalApps applications..."

# 4. Loop through the list and trigger a child job for each
for ($i = 0; $i -lt $TotalApps; $i++) {
    $AppName = $MasterAppList[$i]
    $CurrentAppNumber = $i + 1
    
    Write-Output "[$CurrentAppNumber / $TotalApps] Triggering job for: $AppName"

    $RunbookParams = @{
        "AppDisplayName" = $AppName
    }

    # Start the runbook asynchronously
    Start-AzAutomationRunbook `
        -ResourceGroupName $ResourceGroupName `
        -AutomationAccountName $AutomationAccountName `
        -Name $WorkerRunbookName `
        -Parameters $RunbookParams `
        -RunOn $HybridWorkerGroupName

    # 5. Stagger the jobs to prevent Graph API throttling and stay under the 3-hour limit
    # Skip the sleep on the very last item in the array
    if ($CurrentAppNumber -lt $TotalApps) {
        Write-Output "Sleeping for 30 seconds to avoid Graph API rate limits..."
        Start-Sleep -Seconds 30
    }
}

Write-Output "All $TotalApps worker jobs have been successfully triggered."
